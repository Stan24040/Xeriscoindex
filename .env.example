# ── Required ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# REQUIRED in production — generate with: openssl rand -hex 32
API_KEY=replace_with_strong_random_key

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (leave empty to allow all in dev)
# Example: https://xeriscoindex.up.railway.app,https://xeris.fun
ALLOWED_ORIGINS=

# ── Boost / Monetization ─────────────────────────────────────────────────────
# Your Solana wallet address that receives boost payments
BOOST_WALLET=YOUR_SOLANA_WALLET_ADDRESS_HERE

# ── Data Source (choose ONE) ──────────────────────────────────────────────────
# Default: live XERIS data from DexScreener (Solana/PumpSwap)
USE_XERIS_RPC=false
USE_SIMULATION=false

# Activate when Xeris native mainnet launches:
# USE_XERIS_RPC=true
# XERIS_RPC_URL=https://rpc.xeris.network
# XERIS_WS_URL=wss://rpc.xeris.network
# XERIS_DEX_PROGRAM=XerisSwap1111111111111111111111111111111111
# XERIS_LAUNCHPAD_PROGRAM=XerisLaunch111111111111111111111111111111

# ── Launchpad integration ─────────────────────────────────────────────────────
LAUNCHPAD_API_URL=https://your-xeris-fun.railway.app
