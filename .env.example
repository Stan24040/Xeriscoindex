# ── Required ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# REQUIRED in production — generate with: openssl rand -hex 32
API_KEY=replace_with_strong_random_key

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://xeriscoindex.onrender.com

# ── Boost / Monetization ─────────────────────────────────────────────────────
BOOST_WALLET=YOUR_SOLANA_WALLET_ADDRESS_HERE

# ── Data Source ───────────────────────────────────────────────────────────────
# USE_XERIS_RPC=true  →  pulls live data from XerisCoin testnet node
# USE_SIMULATION=true →  offline demo mode (fake data, no network needed)
# (both false)        →  pulls XERIS/SOL data from DexScreener (Solana/PumpSwap)

USE_XERIS_RPC=false
USE_SIMULATION=false

# ── XerisCoin Testnet Node (SDK v1.3) ─────────────────────────────────────────
# Set these when activating USE_XERIS_RPC=true
# Official testnet seed node (Xeris Technologies LLC)
XERIS_NODE_HOST=138.197.116.81
XERIS_RPC_PORT=56001        # REST API — tx submission + chain queries
XERIS_EXPLORER_PORT=50008   # Block explorer + Solana-compat JSON-RPC

# ── Launchpad integration ─────────────────────────────────────────────────────
LAUNCHPAD_API_URL=https://your-xeris-fun.railway.app
